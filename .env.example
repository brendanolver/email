# Copy to .env (which is gitignored) and fill in real values.
# Never commit this file with real credentials.

ICLOUD_IMAP_HOST=imap.mail.me.com
ICLOUD_IMAP_PORT=993
ICLOUD_USERNAME=you@me.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

VENTRAIP_IMAP_HOST=ventraip.email
VENTRAIP_IMAP_PORT=993
VENTRAIP_USERNAME=you@yourdomain.com
VENTRAIP_PASSWORD=your-mailbox-password

# Prototype-only: how far back to test-fetch from, e.g. 2026-07-10T00:00:00Z
PROTOTYPE_SINCE=2026-07-10T00:00:00Z

# Stage 6: independent scheduler + digest
ANTHROPIC_API_KEY=sk-ant-...
DATA_DIR=/data
DIGEST_EMAIL_TO=brendanolver@me.com
SLACK_WEBHOOK_URL=
